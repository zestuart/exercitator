# Exercitator — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# Required: Gemini API key for SAST security scanning
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Required: intervals.icu API key (Ze)
# Get yours at: https://intervals.icu/settings
INTERVALS_ICU_API_KEY=your-intervals-icu-api-key-here

# Optional: intervals.icu API key (Pam)
# If not set, /pam/ routes return 503
INTERVALS_ICU_API_KEY_PAM=pam-intervals-icu-api-key-here

# Required for production: Tailscale auth key for container networking
# Generate at: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=your-tailscale-auth-key-here

# OAuth (required for production streamable-http mode)
MCP_OAUTH_CLIENT_ID=exercitator
MCP_OAUTH_CLIENT_SECRET=generate-with-openssl-rand-hex-32
MCP_OAUTH_AUTHORIZE_PASSPHRASE=your-passphrase-here
MCP_TOKEN_VERSION=1

# Optional: Anthropic API key for dynamic deity invocations in Praescriptor
# If not set, static fallback invocations are used
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Stryd PowerCenter credentials for FIT enrichment (Ze)
# If not set, Apple Watch + Stryd activities use HealthFit data (lower fidelity)
STRYD_EMAIL=your-stryd-email
STRYD_PASSWORD=your-stryd-password

# Optional: Stryd PowerCenter credentials for FIT enrichment (Pam)
STRYD_EMAIL_PAM=pam-stryd-email
STRYD_PASSWORD_PAM=pam-stryd-password

# Arca Ingens SSH (password contains special chars — use Python file-write, not shell)
QNAP_PASSWORD=your-qnap-password-here
