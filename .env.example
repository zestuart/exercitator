# Exercitator — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# Required: Gemini API key for SAST security scanning
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Required: intervals.icu API key (Ze)
# Get yours at: https://intervals.icu/settings
INTERVALS_ICU_API_KEY=your-intervals-icu-api-key-here

# Optional: intervals.icu API key (Pam)
# If not set, /pam/ routes return 503
INTERVALS_ICU_API_KEY_PAM=pam-intervals-icu-api-key-here

# Required for production: Tailscale auth key for container networking
# Generate at: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=your-tailscale-auth-key-here

# OAuth (required for production streamable-http mode)
MCP_OAUTH_CLIENT_ID=exercitator
MCP_OAUTH_CLIENT_SECRET=generate-with-openssl-rand-hex-32
MCP_OAUTH_AUTHORIZE_PASSPHRASE=your-passphrase-here
MCP_TOKEN_VERSION=1

# Optional: Anthropic API key for dynamic deity invocations in Praescriptor
# If not set, static fallback invocations are used
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Stryd PowerCenter credentials for FIT enrichment (Ze)
# If not set, Apple Watch + Stryd activities use HealthFit data (lower fidelity)
STRYD_EMAIL=your-stryd-email
STRYD_PASSWORD=your-stryd-password

# Optional: Stryd PowerCenter credentials for FIT enrichment (Pam)
STRYD_EMAIL_PAM=pam-stryd-email
STRYD_PASSWORD_PAM=pam-stryd-password

# Optional: FORM Athletica credentials for swim-recommendation swap (Ze)
# If not set, Swim suggestions stay engine-only (no FORM swap).
# Cache path defaults to ~/.cache/form-client/oauth.json; override with
# FORM_CACHE_PATH (e.g. /data/form-cache/oauth.json under Docker).
FORM_EMAIL=your-form-email
FORM_PASSWORD=your-form-password
FORM_CACHE_PATH=

# Optional: HTTP API bearer keys for native clients (Excubitor iOS / watchOS).
# Format: <client>:<userId>:<token>, comma-separated. Each key scopes a device to
# one userId — the API rejects cross-user reads with 403.
# If unset, the HTTP API listener stays disabled (MCP and Praescriptor unaffected).
#   e.g. excubitor-ios:ze:<openssl rand -hex 32>,excubitor-ios:pam:<another>
EXERCITATOR_API_KEYS=
# Optional: override the HTTP API bind address (default 0.0.0.0:8643)
EXERCITATOR_API_BIND_ADDR=0.0.0.0:8643

# Promus DSW (Daily Suggested Workout) emission — bearer token for
# POST /api/ingest/dsw on Promus. Required for the longitudinal
# fitness:readiness:workout corpus build-out. When unset, the emitter
# logs a warn and skips; Praescriptor + the swap layer behave normally.
PROMUS_API=your-promus-bearer-token
# Optional override (default: https://promus.tail7ab379.ts.net).
PROMUS_URL=

# WHOOP strap serial for the Promus health-telemetry source (ze). When ze's
# profile has healthSource: "promus-whoop", the Sleep + HRV readiness
# components are read from this strap's overnight WHOOP data via Promus
# instead of intervals.icu wellness. If today's WHOOP night is missing (strap
# not yet synced) the suggestion hard-fails with status "health_unavailable".
# Reuses PROMUS_API for auth. If unset, ze's suggestions hard-fail.
WHOOP_SERIAL=your-whoop-strap-serial

# Garmin bridge (garmin-bridge/) — Garmin Connect recovery telemetry + activity
# FITs, read by exercitator/praescriptor as the health source (healthSource
# "garmin", or the "auto" WHOOP→Garmin fallback for strap hiatuses). Shared
# bearer key between the bridge and its consumers; GARMIN_URL defaults to the
# compose-internal service (http://garmin-bridge:8655). The garth OAuth token
# is minted out-of-band (garmin-bridge/garmin_login.py) and mounted as a volume
# — it is NOT an env var. If GARMIN_BRIDGE_API_KEY is unset, the Garmin source
# is simply unavailable (auto falls through to a WHOOP-only hard-fail).
GARMIN_BRIDGE_API_KEY=your-garmin-bridge-bearer-token
GARMIN_URL=
# Enable FORM-side DSW emission to Promus. Stays off until Promus #168
# (rename stryd_recommendation_set → vendor_recommendation_set) ships;
# Promus would reject the new field name otherwise. Set to "1" or "true"
# to enable; anything else (or unset) keeps it disabled.
PROMUS_FORM_DSW_ENABLED=

# Cogitator SSH — login password (also unlocks login keychain for docker builds in non-interactive SSH).
# Key auth via ~/.ssh/id_ed25519 is preferred; this is the fallback.
cogitatorPass=your-cogitator-login-password
